<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SMP Negeri 14 Tarakan — Buku Piket Digital</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Zilla+Slab:wght@400;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600;700&display=swap');

  :root{
    --bg:#EDEFE9;
    --panel:#FFFFFF;
    --ink:#202A24;
    --ink-soft:#5B6B60;
    --stamp:#A13D3D;
    --brass:#C79A3E;
    --ok:#4C7A5E;
    --line:#D3D8CE;
    --focus:#2F5D50;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    font-family:'Inter',sans-serif; color:var(--ink); background:var(--bg);
    min-height:100vh;
  }
  h1,h2,h3{font-family:'Zilla Slab',serif; margin:0;}
  .mono{font-family:'IBM Plex Mono',monospace;}
  a{color:inherit;}
  button, a.btn{font-family:'Inter',sans-serif;}

  ::selection{background:var(--brass); color:#fff;}

  /* ---------- Top bar ---------- */
  .topbar{
    position:sticky; top:0; z-index:50;
    background:var(--panel); border-bottom:2px solid var(--ink);
    display:flex; align-items:center; justify-content:space-between;
    padding:12px 22px; gap:12px; flex-wrap:wrap;
  }
  .topbar .brand{display:flex; align-items:center; gap:10px;}
  .bell-mark{
    width:34px; height:34px; border-radius:50%; background:var(--focus); color:#fff;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .brand .names{line-height:1.25;}
  .brand .school{font-family:'Zilla Slab',serif; font-weight:700; font-size:15px;}
  .brand .app{font-size:10.5px; letter-spacing:1.5px; text-transform:uppercase; color:var(--ink-soft);}

  .btn-login{
    background:var(--focus); color:#fff; border:1px solid var(--focus);
    padding:10px 22px; border-radius:3px; font-weight:600; font-size:13.5px;
    text-decoration:none; transition:background .15s ease;
  }
  .btn-login:hover{background:#1f4238;}
  .btn-login:focus-visible{outline:2px solid var(--brass); outline-offset:2px;}

  /* ---------- Hero: signature clock ---------- */
  .hero{
    background:var(--ink); color:#fff;
    padding:34px 22px 30px;
  }
  .hero-inner{
    max-width:1180px; margin:0 auto; display:flex; align-items:flex-end; justify-content:space-between;
    gap:24px; flex-wrap:wrap;
  }
  .hero-id .eyebrow{font-size:11px; letter-spacing:2px; text-transform:uppercase; color:#9FB0A5; margin-bottom:6px;}
  .hero-id h1{font-size:clamp(22px,4vw,32px); font-weight:700; color:#fff;}
  .hero-id .addr{font-size:12.5px; color:#9FB0A5; margin-top:4px;}

  .hero-clock{
    text-align:right;
  }
  .hero-clock .date{font-size:13px; color:#C9D3CC; margin-bottom:2px;}
  .hero-clock .time{
    font-family:'IBM Plex Mono',monospace; font-weight:700; font-size:clamp(36px,6vw,54px);
    letter-spacing:1px; line-height:1; font-variant-numeric:tabular-nums;
  }
  .hero-clock .time .sec{color:var(--brass);}

  .hero-stat{
    display:flex; align-items:center; gap:12px; background:rgba(255,255,255,0.08);
    border:1px solid rgba(255,255,255,0.18); border-radius:4px; padding:12px 18px;
  }
  .hero-stat .num{font-family:'Zilla Slab',serif; font-weight:700; font-size:34px; color:var(--brass);}
  .hero-stat .lbl{font-size:11.5px; color:#C9D3CC; max-width:130px; line-height:1.4;}

  /* ---------- Content ---------- */
  .content{max-width:1180px; margin:0 auto; padding:28px 20px 60px;}

  .bento{
    display:grid;
    grid-template-columns:repeat(12, 1fr);
    gap:18px;
  }
  .card{
    background:var(--panel); border:1px solid var(--line); border-radius:4px;
    padding:20px 22px; display:flex; flex-direction:column;
  }
  .card .eyebrow{
    font-size:10.5px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase;
    color:var(--stamp); margin-bottom:6px;
  }
  .card h2{font-size:17px; margin-bottom:4px;}
  .card .desc{font-size:12px; color:var(--ink-soft); margin-bottom:14px;}

  .span-8{grid-column:span 8;}
  .span-4{grid-column:span 4;}
  .span-6{grid-column:span 6;}
  .span-12{grid-column:span 12;}

  @media (max-width:900px){
    .bento{grid-template-columns:1fr;}
    .span-8,.span-4,.span-6,.span-12{grid-column:span 1;}
    .hero-inner{align-items:flex-start;}
    .hero-clock{text-align:left;}
  }

  /* Pengumuman list */
  .announce-list{display:flex; flex-direction:column; gap:0; max-height:260px; overflow-y:auto;}
  .announce-item{padding:11px 0; border-bottom:1px solid var(--line);}
  .announce-item:last-child{border-bottom:none;}
  .announce-item .a-title{font-weight:600; font-size:13.5px; margin-bottom:2px;}
  .announce-item .a-body{font-size:12.5px; color:var(--ink-soft); white-space:pre-wrap;}

  /* Jadwal piket table */
  table{width:100%; border-collapse:collapse; font-size:13px;}
  thead th{
    text-align:left; font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:0.6px;
    text-transform:uppercase; color:var(--ink-soft); padding:6px 8px; border-bottom:2px solid var(--ink);
  }
  tbody td{padding:8px 8px; border-bottom:1px solid var(--line);}
  tbody tr:last-child td{border-bottom:none;}

  /* Birthday */
  .bday-list{display:flex; flex-direction:column; gap:10px;}
  .bday-item{display:flex; align-items:center; gap:10px; font-size:13.5px;}
  .bday-icon{font-size:18px;}
  .bday-tag{
    font-size:10px; text-transform:uppercase; letter-spacing:0.5px; font-weight:700;
    padding:2px 7px; border-radius:10px; color:#fff;
  }
  .bday-tag.siswa{background:var(--focus);}
  .bday-tag.staff{background:var(--brass);}

  /* Empty state */
  .empty-state{
    flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
    text-align:center; color:var(--ink-soft); font-size:12.5px; padding:20px 10px; gap:6px;
  }
  .empty-state .icon{font-size:26px; opacity:0.6;}

  /* Guest link buttons */
  .guest-grid{display:flex; flex-direction:column; gap:10px;}
  .guest-card{
    display:flex; align-items:center; gap:12px; text-align:left;
    padding:10px 12px; border:1px solid var(--line); border-radius:3px; background:#FBFBF9;
  }
  .guest-card .qr-img{width:64px; height:64px; border:1px solid var(--line); border-radius:2px; background:#fff; flex-shrink:0;}
  .qr-wrap{position:relative; flex-shrink:0;}
  .qr-expand-btn{
    position:absolute; top:-7px; right:-7px; width:22px; height:22px; border-radius:50%;
    background:var(--focus); color:#fff; border:2px solid var(--panel); display:flex; align-items:center;
    justify-content:center; cursor:pointer; padding:0;
  }
  .qr-expand-btn:hover{background:#1f4238;}
  .qr-expand-btn:focus-visible{outline:2px solid var(--brass); outline-offset:2px;}

  .qr-modal-backdrop{
    position:fixed; inset:0; background:rgba(32,42,36,0.55); display:flex; align-items:center;
    justify-content:center; z-index:1000; padding:20px;
  }
  .qr-modal-card{
    background:var(--panel); border-radius:6px; padding:28px 26px 22px; max-width:380px; width:100%;
    text-align:center;
  }
  .qr-modal-card .qm-title{font-family:'Zilla Slab',serif; font-weight:700; font-size:17px; margin-bottom:4px;}
  .qr-modal-card .qm-sub{font-size:12px; color:var(--ink-soft); margin-bottom:18px;}
  .qr-modal-card img{width:100%; max-width:300px; height:auto; border:1px solid var(--line); border-radius:4px; background:#fff;}
  .qr-modal-card .qm-close{
    margin-top:18px; background:var(--ink); color:#fff; border:none; padding:9px 24px;
    border-radius:20px; font-weight:600; font-size:13px; cursor:pointer;
  }
  .qr-modal-card .qm-close:hover{background:#000;}
  .guest-card .g-info{flex:1; min-width:0;}
  .guest-card .g-title{font-weight:700; font-size:13px;}
  .guest-card .g-sub{font-size:10.5px; color:var(--ink-soft);}
  .guest-card .g-link{
    display:inline-block; font-size:11px; font-weight:600; color:var(--focus); text-decoration:none;
    border:1px solid var(--focus); padding:4px 11px; border-radius:20px; margin-top:5px;
  }
  .guest-card .g-link:hover{background:var(--focus); color:#fff;}
  .guest-card .g-link:focus-visible{outline:2px solid var(--brass); outline-offset:2px;}

  /* Placeholder coming soon */
  .soon-badge{
    align-self:flex-start; font-size:10px; font-weight:700; letter-spacing:0.5px; text-transform:uppercase;
    padding:3px 9px; border:1px solid var(--brass); color:var(--brass); border-radius:10px; margin-top:auto;
  }

  .stat-mini-row{display:flex; gap:14px; margin-top:auto;}
  .stat-mini{flex:1; text-align:center; padding:10px 6px; border:1px solid var(--line); border-radius:3px;}
  .stat-mini .n{font-family:'Zilla Slab',serif; font-weight:700; font-size:22px;}
  .stat-mini .l{font-size:10px; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.4px;}

  /* Bar chart */
  .chart-cols{display:grid; grid-template-columns:1fr 1fr; gap:28px;}
  @media (max-width:760px){ .chart-cols{grid-template-columns:1fr;} }
  .chart-title{font-size:12.5px; font-weight:700; color:var(--ink); margin-bottom:10px;}
  .bar-row{display:flex; align-items:center; gap:8px; margin-bottom:7px; font-size:12px;}
  .bar-label{width:130px; flex-shrink:0; color:var(--ink-soft);}
  .bar-row.is-total .bar-label{color:var(--ink); font-weight:700;}
  .bar-track{flex:1; background:var(--bg); border:1px solid var(--line); border-radius:3px; height:15px; position:relative; overflow:hidden;}
  .bar-fill{height:100%; background:var(--focus); border-radius:2px; transition:width .4s ease;}
  .bar-row.is-total .bar-fill{background:var(--stamp);}
  .bar-value{width:24px; text-align:right; font-family:'IBM Plex Mono',monospace; font-weight:700; font-size:12px; flex-shrink:0;}

  footer{
    text-align:center; font-size:11.5px; color:var(--ink-soft); padding:20px; border-top:1px solid var(--line);
  }

  @media (prefers-reduced-motion: reduce){ *{transition:none !important; animation:none !important;} }

  /* Jadwal Pelajaran (skema relasional: slot_waktu + jadwal_pelajaran + kelas + guru + mapel) */
  .jp-scroll{overflow-x:auto; overflow-y:auto; max-height:400px; -webkit-overflow-scrolling:touch; border:1px solid var(--line); border-radius:4px;}
  table.jp-grid{border-collapse:collapse; width:100%; min-width:820px; font-size:11.5px;}
  table.jp-grid th, table.jp-grid td{border:1px solid var(--line); padding:6px 5px; text-align:center; color:var(--ink);}
  table.jp-grid thead th{
    background:var(--ink); color:#fff; font-family:'IBM Plex Mono',monospace; font-size:9.5px;
    text-transform:uppercase; letter-spacing:0.5px; position:sticky; top:0; z-index:2;
  }
  td.jp-jam, th.jp-jam{position:sticky; left:0; width:38px; background:#F6F7F3; font-weight:700; font-family:'IBM Plex Mono',monospace; z-index:1;}
  td.jp-waktu, th.jp-waktu{position:sticky; left:38px; width:68px; background:#F6F7F3; font-size:9.5px; font-family:'IBM Plex Mono',monospace; white-space:nowrap; z-index:1;}
  td.jp-special{font-weight:700; text-transform:uppercase; font-size:10px; letter-spacing:0.4px;}
  td.jp-special.upacara{background:#DCEEDD; color:#2c5c2f;}
  td.jp-special.istirahat{background:#F7DEDC; color:var(--stamp);}
  td.jp-special.literasi{background:#FBEFC9; color:#8a6d1a;}
  td.jp-special.pembiasaan{background:#E7E1F5; color:#4b3a7a;}
  td.jp-special.pembimbingan_wali_kelas{background:#D6EEF2; color:#1a5560;}
  td.jp-kosong{color:var(--ink-soft); font-style:italic;}
  td .jp-kode{font-weight:700;}
  td .jp-guru{display:block; font-size:8.5px; color:var(--ink-soft); margin-top:1px; font-weight:400;}
</style>
</head>
<body>

<div class="topbar">
  <div class="brand">
    <div class="bell-mark" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    </div>
    <div class="names">
      <div class="school">SMP NEGERI 14 TARAKAN</div>
      <div class="app">Buku Piket Digital</div>
    </div>
  </div>
  <a class="btn-login" href="piketlogin.html" target="_blank">Login</a>
</div>

<div class="hero">
  <div class="hero-inner">
    <div class="hero-id">
      <div class="eyebrow">Pemerintah Kota Tarakan · Dinas Pendidikan dan Kebudayaan</div>
      <h1>Papan Informasi Piket</h1>
      <div class="addr">Jl. Bhayangkara RT 66 No. 42, Karang Anyar</div>
    </div>
    <div class="hero-clock">
      <div class="date" id="hero-date">Memuat tanggal…</div>
      <div class="time" id="hero-time">--:--<span class="sec">:--</span></div>
    </div>
    <div class="hero-stat">
      <div class="num" id="stat-tidak-masuk">—</div>
      <div class="lbl">Catatan piket tercatat hari ini (semua jenis)</div>
    </div>
  </div>
</div>

<div class="content">
  <div class="bento">

    <div class="card span-8">
      <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:10px;">
        <div>
          <div class="eyebrow">Jadwal Pelajaran Kelas</div>
          <h2>Hari Ini</h2>
          <div class="desc">Susunan jam pelajaran per kelas hari ini.</div>
        </div>
        <div style="display:flex; gap:8px;">
          <a class="qr-expand-btn" style="position:static; width:30px; height:30px;" href="jadwalsemuakelas.html" target="_blank" rel="noopener" title="Buka jadwal pelajaran lengkap" aria-label="Buka jadwal pelajaran lengkap">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg>
          </a>
          <a class="qr-expand-btn" style="position:static; width:30px; height:30px;" href="kalender.html" target="_blank" rel="noopener" title="Buka kalender pendidikan" aria-label="Buka kalender pendidikan">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>
          </a>
        </div>
      </div>
      <div id="jadwalpelajaran-body"><div class="empty-state"><div class="icon">⏳</div>Memuat jadwal pelajaran…</div></div>
    </div>

    <div class="card span-4">
      <div class="eyebrow">Jadwal Piket</div>
      <h2>Petugas Piket</h2>
      <div class="desc">Jadwal harian petugas piket sekolah.</div>
      <div id="jadwalpiket-body"><div class="empty-state"><div class="icon">⏳</div>Memuat jadwal…</div></div>
    </div>

    <div class="card span-4">
      <div class="eyebrow">Ulang Tahun</div>
      <h2>Hari Ini</h2>
      <div class="desc">Siswa dan guru/staff yang berulang tahun hari ini.</div>
      <div id="bday-body"><div class="empty-state"><div class="icon">⏳</div>Memuat data…</div></div>
    </div>

    <div class="card span-4">
      <div class="eyebrow">Pengumuman</div>
      <h2>Informasi Sekolah</h2>
      <div class="desc">Pemberitahuan terbaru dari sekolah.</div>
      <div id="pengumuman-body"><div class="empty-state"><div class="icon">⏳</div>Memuat pengumuman…</div></div>
    </div>

    <div class="card span-4">
      <div class="eyebrow">Buku Tamu</div>
      <h2>Isi Buku Tamu</h2>
      <div class="desc">Pindai QR atau klik tombol sesuai kategori kunjungan.</div>
      <div class="guest-grid">
        <div class="guest-card">
          <div class="qr-wrap">
            <img class="qr-img" id="qr-umum" alt="QR Tamu Umum"/>
            <button class="qr-expand-btn" data-qr-label="Tamu Umum" data-qr-rel="buku-tamu-publik.html?tamu=umum" title="Perbesar QR" aria-label="Perbesar QR Tamu Umum">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
            </button>
          </div>
          <div class="g-info">
            <div class="g-title">Tamu Umum</div>
            <div class="g-sub">Kunjungan umum</div>
            <a class="g-link" href="buku-tamu-publik.html?tamu=umum">Buka Form</a>
          </div>
        </div>
        <div class="guest-card">
          <div class="qr-wrap">
            <img class="qr-img" id="qr-khusus" alt="QR Tamu Khusus"/>
            <button class="qr-expand-btn" data-qr-label="Tamu Khusus" data-qr-rel="buku-tamu-publik.html?tamu=khusus" title="Perbesar QR" aria-label="Perbesar QR Tamu Khusus">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
            </button>
          </div>
          <div class="g-info">
            <div class="g-title">Tamu Khusus</div>
            <div class="g-sub">Dinas / kedinasan</div>
            <a class="g-link" href="buku-tamu-publik.html?tamu=khusus">Buka Form</a>
          </div>
        </div>
        <div class="guest-card">
          <div class="qr-wrap">
            <img class="qr-img" id="qr-walisiswa" alt="QR Wali Siswa"/>
            <button class="qr-expand-btn" data-qr-label="Wali / Siswa" data-qr-rel="buku-tamu-publik.html?tamu=wali/siswa" title="Perbesar QR" aria-label="Perbesar QR Wali Siswa">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
            </button>
          </div>
          <div class="g-info">
            <div class="g-title">Wali / Siswa</div>
            <div class="g-sub">Menjemput / urusan siswa</div>
            <a class="g-link" href="buku-tamu-publik.html?tamu=wali/siswa">Buka Form</a>
          </div>
        </div>
      </div>
    </div>

    <div class="card span-12">
      <div class="eyebrow">Informasi Lainnya</div>
      <h2>Statistik Ketidakhadiran Hari Ini</h2>
      <div class="desc">Ringkasan siswa dan guru yang tidak masuk sesuai kategori, per hari ini.</div>
      <div class="chart-cols">
        <div>
          <div class="chart-title">Siswa Tidak Masuk</div>
          <div id="chart-siswa"><div class="empty-state"><div class="icon">⏳</div>Memuat data…</div></div>
        </div>
        <div>
          <div class="chart-title">Guru Tidak Masuk</div>
          <div id="chart-guru"><div class="empty-state"><div class="icon">⏳</div>Memuat data…</div></div>
        </div>
      </div>
    </div>

  </div>
</div>

<footer>SMP Negeri 14 Tarakan &middot; Buku Piket Digital &middot; Ditampilkan otomatis, diperbarui setiap saat halaman dibuka</footer>

<script>
(function(){
  const SUPABASE_URL = 'https://myvwsuxsfttuoxprmzsb.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_p_2iyDthpvO3-7Tc24gWKA_suOqX2-j';

  // Database kedua, khusus untuk data Jadwal Pelajaran
  const JADWAL_SUPABASE_URL = 'https://myjyxpcdyzaydqxlyeee.supabase.co';
  const JADWAL_SUPABASE_KEY = 'sb_publishable_4UhZdrW-8Oy1aR31VdSCrA_m5CgcqeA';

  async function sbJadwal(path){
    try{
      const res = await fetch(`${JADWAL_SUPABASE_URL}/rest/v1/${path}`, {
        headers: { 'apikey': JADWAL_SUPABASE_KEY }
      });
      if(!res.ok){
        let detail = '';
        try{ const j = await res.json(); detail = j.message || JSON.stringify(j); }catch(e){ detail = res.statusText; }
        console.error('Jadwal Pelajaran error:', res.status, detail);
        return { __error: `(${res.status}) ${detail}` };
      }
      return await res.json();
    }catch(e){
      console.error('Jadwal Pelajaran fetch error:', e);
      return { __error: e.message };
    }
  }

  async function sb(path){
    try{
      const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
        headers: { 'apikey': SUPABASE_KEY }
      });
      if(!res.ok) return null;
      return await res.json();
    }catch(e){ console.error(e); return null; }
  }
  const enc = encodeURIComponent;

  // ---------- Live clock ----------
  function tickClock(){
    const now = new Date();
    document.getElementById('hero-date').textContent = now.toLocaleDateString('id-ID', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
    const h = String(now.getHours()).padStart(2,'0');
    const m = String(now.getMinutes()).padStart(2,'0');
    const s = String(now.getSeconds()).padStart(2,'0');
    document.getElementById('hero-time').innerHTML = `${h}:${m}<span class="sec">:${s}</span>`;
  }
  tickClock();
  setInterval(tickClock, 1000);

  function todayStr(){ return new Date().toISOString().slice(0,10); }
  function emptyState(icon, msg){ return `<div class="empty-state"><div class="icon">${icon}</div>${msg}</div>`; }

  // ---------- Jadwal Pelajaran Hari Ini ----------
  async function loadJadwalPelajaran(){
    const el = document.getElementById('jadwalpelajaran-body');
    const HARI_LIST = ['MINGGU','SENIN','SELASA','RABU','KAMIS','JUMAT','SABTU'];
    const HARI_LABEL = {SENIN:'Senin',SELASA:'Selasa',RABU:'Rabu',KAMIS:'Kamis',JUMAT:'Jumat',SABTU:'Sabtu'};
    const JENIS_LABEL = {
      UPACARA:'Upacara Bendera', ISTIRAHAT:'Istirahat', LITERASI:'Literasi',
      PEMBIASAAN:'Pembiasaan', PEMBIMBINGAN_WALI_KELAS:'Pembimbingan Wali Kelas'
    };
    const KELAS_ORDER = ['VII-1','VII-2','VII-3','VII-4','VIII-1','VIII-2','VIII-3','VIII-4','IX-1','IX-2','IX-3'];
    const todayHari = HARI_LIST[new Date().getDay()];

    if(todayHari === 'MINGGU'){
      el.innerHTML = emptyState('📘','Hari libur, tidak ada jadwal pelajaran.');
      return;
    }

    const [slotsRes, kelasRes, jadwalRes] = await Promise.all([
      sbJadwal(`slot_waktu?select=*&order=jam_mulai.asc`),
      sbJadwal(`kelas?select=nama_kelas&order=nama_kelas.asc`),
      sbJadwal(`jadwal_pelajaran?select=kelas:kelas_id(nama_kelas),slot:slot_waktu_id(id,hari,jam_ke,jam_mulai,jam_selesai,jenis_slot),pengajar:kode_pengajar_id(kode,guru:guru_id(nama),mapel:mata_pelajaran_id(nama_mapel))`),
    ]);

    const firstErr = [slotsRes, kelasRes, jadwalRes].find(r => r === null || (r && r.__error));
    if(firstErr){
      const msg = (firstErr && firstErr.__error) ? firstErr.__error : 'Tidak diketahui';
      el.innerHTML = emptyState('📘', `Gagal memuat jadwal pelajaran.<br><span class="mono" style="font-size:10.5px;">${msg}</span>`);
      return;
    }

    const daySlots = (slotsRes||[]).filter(s=>s.hari===todayHari).sort((a,b)=>String(a.jam_mulai).localeCompare(String(b.jam_mulai)));
    if(!daySlots.length){ el.innerHTML = emptyState('📘','Jadwal pelajaran hari ini belum diisi.'); return; }

    const kelasNames = (kelasRes||[]).map(k=>k.nama_kelas).filter(Boolean);
    const kelasList = KELAS_ORDER.filter(k => kelasNames.includes(k));
    const finalKelasList = kelasList.length ? kelasList : kelasNames;

    const jMap = new Map();
    (jadwalRes||[]).forEach(r=>{
      if(!r.slot || !r.kelas) return;
      jMap.set(r.slot.id + '|' + r.kelas.nama_kelas, r);
    });

    const fmtTime = (t) => t ? String(t).slice(0,5).replace(':','.') : '';

    const headerCells = finalKelasList.map(k=>`<th>${k}</th>`).join('');
    const rows = daySlots.map(s=>{
      const time = `${fmtTime(s.jam_mulai)}–${fmtTime(s.jam_selesai)}`;
      if(s.jenis_slot !== 'REGULER'){
        const cls = String(s.jenis_slot||'').toLowerCase();
        return `<tr>
          <td class="jp-jam">–</td>
          <td class="jp-waktu">${time}</td>
          <td class="jp-special ${cls}" colspan="${finalKelasList.length}">${JENIS_LABEL[s.jenis_slot]||s.jenis_slot}</td>
        </tr>`;
      }
      const cells = finalKelasList.map(k=>{
        const row = jMap.get(s.id + '|' + k);
        if(!row || !row.pengajar) return `<td class="jp-kosong">—</td>`;
        const kode = row.pengajar.kode || '';
        const guruNama = (row.pengajar.guru && row.pengajar.guru.nama) || '';
        return `<td><span class="jp-kode">${kode}</span>${guruNama?`<span class="jp-guru">${guruNama}</span>`:''}</td>`;
      }).join('');
      return `<tr><td class="jp-jam">${s.jam_ke ?? '-'}</td><td class="jp-waktu">${time}</td>${cells}</tr>`;
    }).join('');

    el.innerHTML = `
      <div style="font-size:11.5px;color:var(--ink-soft);margin-bottom:8px;">Jadwal untuk hari <b>${HARI_LABEL[todayHari]}</b></div>
      <div class="jp-scroll">
        <table class="jp-grid">
          <thead>
            <tr><th class="jp-jam">Jam</th><th class="jp-waktu">Waktu</th>${headerCells}</tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    `;
  }
  // ---------- QR Code otomatis untuk Buku Tamu ----------
  function fullUrl(relative){ return new URL(relative, window.location.href).href; }
  function qrImgSrc(url, size){ return `https://api.qrserver.com/v1/create-qr-code/?size=${size||'140x140'}&data=${encodeURIComponent(url)}`; }
  function setupGuestQRCodes(){
    document.getElementById('qr-umum').src = qrImgSrc(fullUrl('buku-tamu-publik.html?tamu=umum'));
    document.getElementById('qr-khusus').src = qrImgSrc(fullUrl('buku-tamu-publik.html?tamu=khusus'));
    document.getElementById('qr-walisiswa').src = qrImgSrc(fullUrl('buku-tamu-publik.html?tamu=wali/siswa'));

    document.querySelectorAll('.qr-expand-btn[data-qr-label]').forEach(btn=>{
      btn.addEventListener('click', ()=>{
        openQrModal(btn.dataset.qrLabel, fullUrl(btn.dataset.qrRel));
      });
    });
  }

  function closeQrModal(){
    const el = document.getElementById('qr-modal-backdrop');
    if(el) el.remove();
  }
  function openQrModal(label, url){
    closeQrModal();
    const wrap = document.createElement('div');
    wrap.innerHTML = `
      <div class="qr-modal-backdrop" id="qr-modal-backdrop">
        <div class="qr-modal-card">
          <div class="qm-title">${label}</div>
          <div class="qm-sub">Pindai QR ini dari jarak yang sesuai</div>
          <img src="${qrImgSrc(url, '400x400')}" alt="QR ${label}"/>
          <div><button class="qm-close" id="qr-modal-close">Tutup</button></div>
        </div>
      </div>
    `;
    document.body.appendChild(wrap.firstElementChild);
    const backdrop = document.getElementById('qr-modal-backdrop');
    backdrop.addEventListener('click', (e)=>{ if(e.target===backdrop) closeQrModal(); });
    document.getElementById('qr-modal-close').addEventListener('click', closeQrModal);
    document.addEventListener('keydown', function escHandler(e){
      if(e.key === 'Escape'){ closeQrModal(); document.removeEventListener('keydown', escHandler); }
    });
  }

  async function loadPengumuman(){
    const el = document.getElementById('pengumuman-body');
    const rows = await sb(`info_landing?jenis=eq.pengumuman&aktif=eq.true&select=*&order=urutan.asc`);
    if(!rows || !rows.length){ el.innerHTML = emptyState('📭','Belum ada pengumuman.'); return; }
    el.innerHTML = `<div class="announce-list">${rows.map(r=>`
      <div class="announce-item">
        <div class="a-title">${r.judul||'—'}</div>
        <div class="a-body">${r.konten||''}</div>
      </div>
    `).join('')}</div>`;
  }

  // ---------- Jadwal Piket ----------
  async function loadJadwalPiket(){
    const el = document.getElementById('jadwalpiket-body');
    const rows = await sb(`jadwal_piket?aktif=eq.Y&select=hari,nama`);
    if(rows === null){ el.innerHTML = emptyState('🕘','Gagal memuat jadwal piket.'); return; }
    if(!rows.length){ el.innerHTML = emptyState('🕘','Jadwal piket belum diisi.'); return; }

    const HARI_ORDER = ['Senin','Selasa','Rabu','Kamis','Jumat','Sabtu','Minggu'];
    const grouped = {};
    rows.forEach(r=>{
      const hari = r.hari || '—';
      if(!grouped[hari]) grouped[hari] = [];
      grouped[hari].push(r.nama);
    });
    const hariList = Object.keys(grouped).sort((a,b)=>{
      const ia = HARI_ORDER.indexOf(a), ib = HARI_ORDER.indexOf(b);
      return (ia===-1?99:ia) - (ib===-1?99:ib);
    });

    el.innerHTML = `<table><tbody>${hariList.map(h=>`
      <tr><td><b>${h}</b></td><td>${grouped[h].join(', ')}</td></tr>
    `).join('')}</tbody></table>`;
  }

  // ---------- Grafik batang: ketidakhadiran siswa & guru ----------
  function renderBarChart(containerEl, items){
    const max = Math.max(1, ...items.filter(i=>!i.isTotal).map(i=>i.value));
    containerEl.innerHTML = items.map(i => {
      const pct = i.isTotal ? 100 : Math.round((i.value / max) * 100);
      return `
        <div class="bar-row ${i.isTotal ? 'is-total' : ''}">
          <div class="bar-label">${i.label}</div>
          <div class="bar-track"><div class="bar-fill" style="width:${i.isTotal ? Math.min(100, pct) : pct}%;"></div></div>
          <div class="bar-value">${i.value}</div>
        </div>
      `;
    }).join('');
  }

  async function loadChartSiswa(){
    const el = document.getElementById('chart-siswa');
    const rows = await sb(`v_statistik_ketidakhadiran?tanggal=eq.${todayStr()}&select=jenis,jumlah`);
    if(rows===null){ el.innerHTML = emptyState('📊','Gagal memuat data.'); return; }

    const counts = {};
    let total = 0;
    rows.forEach(r=>{ counts[r.jenis] = (counts[r.jenis]||0) + Number(r.jumlah); total += Number(r.jumlah); });

    const categories = [
      { key:'Sakit', label:'Sakit' },
      { key:'Terlambat', label:'Terlambat' },
      { key:'Izin Masuk', label:'Ijin Masuk' },
      { key:'Izin Pulang', label:'Ijin Pulang' },
      { key:'Dijemput Ortu', label:'Dijemput Ortu' },
      { key:'Lainnya', label:'Lainnya' },
    ];
    const items = [{ label:'Total Hari Ini', value: total, isTotal:true }]
      .concat(categories.map(c => ({ label:c.label, value: counts[c.key]||0 })));

    renderBarChart(el, items);
  }

  async function loadChartGuru(){
    const el = document.getElementById('chart-guru');
    const rows = await sb(`v_statistik_guru?tanggal=eq.${todayStr()}&select=alasan,jumlah`);
    if(rows===null){ el.innerHTML = emptyState('📊','Gagal memuat data.'); return; }

    const counts = {};
    let total = 0;
    rows.forEach(r=>{ counts[r.alasan] = (counts[r.alasan]||0) + Number(r.jumlah); total += Number(r.jumlah); });

    const categories = [
      { key:'Sakit', label:'Sakit' },
      { key:'Cuti', label:'Cuti' },
      { key:'Urusan Keluarga', label:'Urusan Keluarga' },
      { key:'Tugas Dinas', label:'Tugas Dinas' },
      { key:'Kendala Akses & Situasional', label:'Kendala Akses & Situasional' },
      { key:'Administrasi & Birokrasi', label:'Administrasi & Birokrasi' },
    ];
    const items = [{ label:'Total Hari Ini', value: total, isTotal:true }]
      .concat(categories.map(c => ({ label:c.label, value: counts[c.key]||0 })));

    renderBarChart(el, items);
  }

  // ---------- Ulang Tahun (hari ini & besok) ----------
  async function loadUlangTahun(){
    const el = document.getElementById('bday-body');
    const rows = await sb(`v_ulang_tahun?select=*`);

    if(rows === null){
      el.innerHTML = emptyState('🎂','Data tanggal lahir belum tersedia.');
      return;
    }
    if(!rows.length){ el.innerHTML = emptyState('🎂','Tidak ada yang berulang tahun hari ini atau besok.'); return; }

    const matches = rows.map(r => ({ nama:r.nama, kelas:r.kelas, tag:r.tipe, when: r.saat==='hari_ini' ? 'hari-ini' : 'besok' }));

    const renderGroup = (label, items) => items.length ? `
      <div style="margin-bottom:10px;">
        <div style="font-size:10.5px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;color:var(--ink-soft);margin-bottom:6px;">${label}</div>
        <div class="bday-list">
          ${items.map(m=>`
            <div class="bday-item">
              <span class="bday-icon">🎂</span>
              <span>${m.nama}${m.kelas ? ' <span class="mono" style="color:var(--ink-soft);font-size:11.5px;">('+m.kelas+')</span>' : ''}</span>
              <span class="bday-tag ${m.tag==='siswa'?'siswa':'staff'}">${m.tag==='siswa'?'Siswa':'Staff'}</span>
            </div>
          `).join('')}
        </div>
      </div>
    ` : '';

    const todays = matches.filter(m=>m.when==='hari-ini');
    const tomorrows = matches.filter(m=>m.when==='besok');
    el.innerHTML = renderGroup('Hari Ini', todays) + renderGroup('Besok', tomorrows);
  }

  // ---------- Total catatan piket hari ini ----------
  async function loadStatTidakMasuk(){
    const rows = await sb(`v_statistik_ketidakhadiran?tanggal=eq.${todayStr()}&select=jumlah`);
    const total = rows ? rows.reduce((sum,r)=> sum + Number(r.jumlah), 0) : 0;
    document.getElementById('stat-tidak-masuk').textContent = rows ? total : '0';
  }

  setupGuestQRCodes();
  loadPengumuman();
  loadJadwalPiket();
  loadJadwalPelajaran();
  loadChartSiswa();
  loadChartGuru();
  loadUlangTahun();
  loadStatTidakMasuk();
})();
</script>
</body>
</html>
